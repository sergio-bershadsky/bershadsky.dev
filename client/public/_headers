# Cloudflare Pages headers — applied at the edge.

# Long-cache hashed build assets (Vite emits hashes in filenames).
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Images are content-addressed by name; cache hard but allow revalidation.
/images/*
  Cache-Control: public, max-age=2592000

# Static data is updated with each deploy — short TTL so new posts appear quickly.
/data/*
  Cache-Control: public, max-age=300, must-revalidate

# HTML must revalidate so prerendered <head> updates are picked up promptly.
/*.html
  Cache-Control: public, max-age=0, must-revalidate
/
  Cache-Control: public, max-age=0, must-revalidate

# Sitemap / robots.
/sitemap.xml
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600

# Baseline security headers for every response.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=()
